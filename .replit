modules = ["nodejs-20", "web", "python-3.11", "postgresql-16"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"
packages = ["ffmpeg", "jq"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 23636
externalPort = 6800

[env]
PORT = "5000"

[deployment]
deploymentTarget = "autoscale"
run = ["node", "./dist/index.cjs"]
build = ["npm", "run", "build"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "validate-abilities"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "validate-pitch-mix"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "validate-all"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "validate-rosters"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "validate-objects-authz"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "verify-db-invariants"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "validate-abilities"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx tsx scripts/validate-abilities.ts"

[[workflows.workflow]]
name = "validate-pitch-mix"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx tsx scripts/validate-pitch-mix.ts"

[[workflows.workflow]]
name = "validate-all"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx tsx scripts/validate-all.ts"

[[workflows.workflow]]
name = "validate-rosters"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx tsx scripts/validate-roster-structure.ts && npx tsx scripts/validate-ovr-dist.ts"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "validate-objects-authz"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx tsx scripts/verify-objects-authz.ts"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "verify-db-invariants"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx tsx scripts/verify-db-invariants.ts --all"

[workflows.workflow.metadata]
outputType = "console"

[agent]
integrations = ["javascript_database:1.0.0", "javascript_openai_ai_integrations:2.0.0", "javascript_object_storage:2.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000

[objectStorage]
defaultBucketID = "replit-objstore-b5b193dc-3078-4af9-b9c8-69568c85964d"
